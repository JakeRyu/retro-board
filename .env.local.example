# ─── NextAuth.js v5 ───────────────────────────────────────────────────────
# 32+ char random string. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=

# Optional. Defaults to http://localhost:3000 in dev.
# Set in production to the deployed origin (e.g. https://retro-board.example.com).
# AUTH_URL=

# ─── Microsoft Entra ID provider ──────────────────────────────────────────
# From Azure portal → Microsoft Entra ID → App registrations → (your app)
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=

# Single-tenant: pin to BW directory (tenant) ID so only org members can sign in.
# Format: https://login.microsoftonline.com/<tenant-id>/v2.0   (NO trailing slash —
# Auth.js does strict OIDC issuer comparison and the discovery endpoint returns
# the issuer without a trailing slash. A trailing slash here causes
# "OperationProcessingError: response body issuer property does not match".)
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# ─── Azure Cosmos DB ──────────────────────────────────────────────────────
# Local dev: Cosmos DB Emulator (default https://localhost:8081)
# Prod: https://<account>.documents.azure.com:443/
COSMOS_ENDPOINT=https://localhost:8081

# Local emulator only. In production, leave COSMOS_KEY unset — the server uses
# DefaultAzureCredential (managed identity in App Service, az login locally)
# and requires the principal to have the "Cosmos DB Built-in Data Contributor"
# role on the account.
# Default emulator key below — NOT a secret, hard-coded in the emulator.
COSMOS_KEY=C2y6yDjf5/R+ob0N8A7Cgv30VRDJIWEHLM+4QDU5DE2nQ9nDuVTqobD4b8mGGyPMbIZnqyMsEcaGQy67XIw/Jw==
